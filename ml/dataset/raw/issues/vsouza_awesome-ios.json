    {
        "id": 4018682665,
        "number": 3268,
        "title": "FileShot.io – Cross-platform zero-knowledge file sharing (iOS Safari compatible)",
        "state": "closed",
        "created_at": "2026-03-03T21:00:08Z",
        "updated_at": "2026-04-22T15:47:48Z",
        "closed_at": "2026-04-22T15:47:47Z",
        "author": "FileShot",
        "comments": 1,
        "labels": [],
        "assignees": [],
        "locked": false,
        "body": "Hi — I'd like to suggest **FileShot.io** for this list.\n\nIt's a privacy-first file sharing tool that works seamlessly on iOS. Files are AES-256-GCM encrypted in the browser on any device — including iPhone/iPad — using the Web Crypto API. The decryption key lives only in the URL fragment.\n\nUseful for iOS developers or teams who need to share builds, assets, or sensitive data securely without a cloud account.\n\n- No account required\n- MIT licensed\n- Works in Safari on iOS\n- Self-hostable Node.js backend\n\nGitHub: https://github.com/FileShot/FileShotZKE\nSite: https://fileshot.io",
        "url": "https://github.com/vsouza/awesome-ios/issues/3268"
    },
