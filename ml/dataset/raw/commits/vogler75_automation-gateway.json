    },
    {
        "sha": "e0e5dfb4327c23387365a5e317e10dc4ef0c4c08",
        "author": "Andreas Vogler",
        "email": "andreas.vogler@me.com",
        "date": "2025-11-24T11:51:09Z",
        "message": "Upgrade Gradle, Kotlin, and refactor AuthService async code\n\nUpgrades Gradle to 9.2.1 and Kotlin to 2.2.21. Refactors AuthService to use cleaner executeBlocking with Callable, removing manual Promise handling. Updates dependency declarations in build.gradle files to use the short notation. Adds JVM toolchain configuration for Kotlin (Java 23). Moves JWTAuthHandler companion object methods to the top-level companion object. Adds foojay-resolver-convention plugin to settings.gradle.",
        "url": "https://github.com/vogler75/automation-gateway/commit/e0e5dfb4327c23387365a5e317e10dc4ef0c4c08"
    },
