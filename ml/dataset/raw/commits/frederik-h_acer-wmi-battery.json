    {
        "sha": "66642b8ecae8ae39612da1fe582f606feb474366",
        "author": "Frederik Harwath",
        "email": "frederik@harwath.name",
        "date": "2022-06-12T18:02:00Z",
        "message": "Add battery calibration support\n\nThis commit adds initial support for battery calibration. The\ncalibration mode can be enabled and disabled through sysfs, but the\nWMI events that indicate the charging states and the completion of the\ncalibration are not being handled yet. Those events are logged as\nunhandled WMI events with ids 8 (charging) and 11 (calibration status)\nto the kernel log. After the calibration, the mode must be disabled\nmanually.",
        "url": "https://github.com/frederik-h/acer-wmi-battery/commit/66642b8ecae8ae39612da1fe582f606feb474366"
    },
