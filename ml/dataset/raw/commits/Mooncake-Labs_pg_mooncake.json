    {
        "sha": "5d10677eb0854268021644c982c455838b9fdcee",
        "author": "Cheng Chen",
        "email": "cheng@mooncakelabs.com",
        "date": "2025-03-17T19:04:05Z",
        "message": "Rearchitect pg_mooncake\n\npg_mooncake v0.2 implements a client-server architecture. Postgres backends are the clients, communicating via IPC with a background worker acting as the server\n\nThe background worker runs moonlink to replicate Postgres tables to mooncake tables. These mooncake tables function as real-time columnstore mirrors, and read queries on them are routed to DuckDB for fast analytics",
        "url": "https://github.com/Mooncake-Labs/pg_mooncake/commit/5d10677eb0854268021644c982c455838b9fdcee"
    },
