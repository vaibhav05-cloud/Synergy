    {
        "sha": "e20c99e5d0f83b26216c7244b366f67ee14a3e18",
        "author": "JonasS",
        "email": "jonass@dev.jsje.de",
        "date": "2019-02-17T00:53:21Z",
        "message": "Fixes #13 - Use user-supplied or default-constructed string_type for invalid enumerators\n- invalid enumerators now return wise_enum::invalid_enumerator_string_value (constexpr string_type)\n- value can be supplied using WISE_ENUM_INVALID_ENUMERATOR_STRING_VALUE macro\n- if the macro is not defined, string_type{} is used (which is non-breaking, as char const* default-constructs to nullptr and string_view also default-constructs as (nullptr, 0), which is the non-standard conforming behaviour observed on implementations where string_view{nullptr} works)",
        "url": "https://github.com/quicknir/wise_enum/commit/e20c99e5d0f83b26216c7244b366f67ee14a3e18"
    },
