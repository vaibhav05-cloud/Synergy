    {
        "sha": "6f209f8d2ac4b4d130235fddbb963a74c59a217e",
        "author": "cedrozor",
        "email": "cedrozor@gmail.com",
        "date": "2021-03-07T16:07:45Z",
        "message": "FreeRDP is now built as a dll instead of an executable for better modularity and to reduce the risk of false positive detection of wfreerdp.exe by some antiviruses (mostly cloud based)\nembedded interact.js and simple-keyboard (nodejs modules) into myrtille in order to remove dependencies on external CDNs (ans thus allow myrtille to be used standalone and not subject to external changes)",
        "url": "https://github.com/myrtille-rdp/myrtille/commit/6f209f8d2ac4b4d130235fddbb963a74c59a217e"
    },
    {
        "sha": "b89e372e3cc6967acd6d48557796b62f3d822636",
        "author": "cedrozor",
        "email": "cedrozor@gmail.com",
        "date": "2021-02-21T16:58:04Z",
        "message": "fixed a problem with the creation of the self-signed certificate that prevented Myrtille from installing correctly on Windows Server 2012 R2 (thanks camjcorley)",
        "url": "https://github.com/myrtille-rdp/myrtille/commit/b89e372e3cc6967acd6d48557796b62f3d822636"
    },
    {
        "sha": "defab47c672cd26f315e0242848d4ae87ed7ba6b",
        "author": "cedrozor",
        "email": "cedrozor@gmail.com",
        "date": "2021-02-21T16:21:23Z",
        "message": "Merge pull request #274 from camjcorley/master\n\nServer 2012 R2 Compatibility",
        "url": "https://github.com/myrtille-rdp/myrtille/commit/defab47c672cd26f315e0242848d4ae87ed7ba6b"
    },
    {
        "sha": "058ed822a7de051c9db14df7623357896f437209",
        "author": "cedrozor",
        "email": "cedrozor@gmail.com",
        "date": "2021-02-20T17:19:24Z",
        "message": "a session can now be shared directly by url (simply copy & paste the page url then share it), with owner rights (web.config, can be disabled for anti-spoofing protection)\nregion updates are now dropped by the gateway if the client latency is above the image cache duration (1 sec); only fullscreen updates are sent\ndisplay updates can now be distributed across concurrent websockets (round robin load balancing) to reduce lag in case of network issues (config.js, default 5 websockets: 1 up 4 down). CAUTION! IIS on Windows client OSes (7, 8, 10) is limited to 10 simultaneous connections only - across all http sessions - and will hang after that! use Windows Server editions for production environments\nthe mouse move sampling rate is now decreased automatically in case of low bandwidth (default 100%, config.js)\nrefactoring",
        "url": "https://github.com/myrtille-rdp/myrtille/commit/058ed822a7de051c9db14df7623357896f437209"
    },
