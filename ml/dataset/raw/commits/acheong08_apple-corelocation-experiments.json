    {
        "sha": "e8a55cb265cc46c11cbdcc56c7c1efcf88514956",
        "author": "zja",
        "email": "junan_zhang@maxnetsys.com.cn",
        "date": "2026-04-29T15:44:43Z",
        "message": "fix: zero-pad MAC address hex bytes in Decode()\n\nEach byte in the BSSID must be zero-padded to 2 hex digits.\nPreviously %x formatting would omit leading zeros per byte,\nproducing invalid BSSIDs like '70:65:82:e2:72:2' instead of\n'70:65:82:e2:72:02'. Now uses %02x per byte via binary.BigEndian.",
        "url": "https://github.com/acheong08/apple-corelocation-experiments/commit/e8a55cb265cc46c11cbdcc56c7c1efcf88514956"
    },
